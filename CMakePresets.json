{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "_base",
      "hidden": true,
      "cacheVariables": {
        "DJVIEW_BUILD_TRANSLATIONS": "ON"
      }
    },
    {
      "name": "_vcpkg",
      "hidden": true,
      "inherits": "_base",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
    },

    {
      "name": "windows-x64",
      "displayName": "Windows x64",
      "description": "MSVC x64 build with Qt6 via vcpkg (Debug + Release)",
      "inherits": "_vcpkg",
      "binaryDir": "${sourceDir}/build/win-x64",
      "generator": "Visual Studio 18 2026",
      "architecture": { "value": "x64", "strategy": "set" },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "windows-arm64",
      "displayName": "Windows ARM64",
      "description": "MSVC ARM64 build with Qt6 via vcpkg (Debug + Release)",
      "inherits": "_vcpkg",
      "binaryDir": "${sourceDir}/build/win-arm64",
      "generator": "Visual Studio 18 2026",
      "architecture": { "value": "arm64", "strategy": "set" },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-windows"
      }
    },

    {
      "name": "linux-x64-release",
      "displayName": "Linux x64 Release",
      "description": "GCC/Clang Release build with system Qt6",
      "inherits": "_base",
      "binaryDir": "${sourceDir}/build/linux-x64-release",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-x64-debug",
      "displayName": "Linux x64 Debug",
      "description": "GCC/Clang Debug build with system Qt6",
      "inherits": "_base",
      "binaryDir": "${sourceDir}/build/linux-x64-debug",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "windows-x64-release",
      "displayName": "Build Windows x64 Release",
      "configurePreset": "windows-x64",
      "configuration": "Release"
    },
    {
      "name": "windows-x64-debug",
      "displayName": "Build Windows x64 Debug",
      "configurePreset": "windows-x64",
      "configuration": "Debug"
    },
    {
      "name": "windows-arm64-release",
      "displayName": "Build Windows ARM64 Release",
      "configurePreset": "windows-arm64",
      "configuration": "Release"
    },
    {
      "name": "linux-x64-release",
      "displayName": "Build Linux x64 Release",
      "configurePreset": "linux-x64-release"
    },
    {
      "name": "linux-x64-debug",
      "displayName": "Build Linux x64 Debug",
      "configurePreset": "linux-x64-debug"
    }
  ]
}
